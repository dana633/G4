
import pandas as pd
import numpy as np
import matplotlib.pyplot as plt
import seaborn as sns

df = pd.read_csv("carbon_emission_dataset_with_Industry.csv")
print("First 5 Rows:")
print(df.head())

print("\nDataset Shape:")
print(df.shape)

print("\nColumn Names:")
print(df.columns)
print("\nDataset Info:")
print(df.info())
print("\nStatistical Summary:")
print(df.describe())


print("\nMissing Values:")
print(df.isnull().sum())

print("\nMissing Value Percentage:")
print((df.isnull().sum() / len(df)) * 100)

print("\nDuplicate Rows:")
print(df.duplicated().sum())

df.drop_duplicates(inplace=True)

df['Date'] = pd.to_datetime(df['Date'])

# Verify Data Types After Cleaning
print("\nDataset Info After Cleaning:")
print(df.info())

# Final Shape After Cleaning
print("\nFinal Dataset Shape:")
print(df.shape)
# ==========================================
# Section 3: Exploratory Analysis
# ==========================================

columns = [
    'Total_Energy_Consumption_kWh',
    'Renewable_Energy_Consumption_kWh',
    'NonRenewable_Energy_Consumption_kWh',
    'Production_Output_Units',
    'Supply_Chain_Transport_km'
]

# Basic Statistics
for col in columns:
    print(f"\nStatistics for {col}")
    print("Mean:", df[col].mean())
    print("Median:", df[col].median())
    print("Max:", df[col].max())
    print("Min:", df[col].min())

# Distribution Plots
for col in columns:
    plt.figure(figsize=(8,5))
    sns.histplot(df[col], kde=True)
    plt.title(f"Distribution of {col}")
    plt.show()

# Frequency Bar Charts
for col in columns:
    plt.figure(figsize=(8,5))
    bins = pd.cut(df[col], bins=10)
    bins.value_counts().sort_index().plot(kind='bar')
    plt.title(f"Frequency of {col}")
    plt.xlabel(col)
    plt.ylabel("Frequency")
    plt.show()

# Energy Consumption Over Time
plt.figure(figsize=(12,6))

plt.plot(df['Date'],
         df['Total_Energy_Consumption_kWh'],
         label='Total Energy')

plt.plot(df['Date'],
         df['Renewable_Energy_Consumption_kWh'],
         label='Renewable Energy')

plt.plot(df['Date'],
         df['NonRenewable_Energy_Consumption_kWh'],
         label='Non-Renewable Energy')

plt.title("Energy Consumption Over Time")
plt.xlabel("Date")
plt.ylabel("kWh")
plt.legend()
plt.show()

# Carbon Emissions vs Total Energy
plt.figure(figsize=(8,5))

sns.scatterplot(
    x='Total_Energy_Consumption_kWh',
    y='Carbon_Emission_tCO2e_TARGET',
    data=df
)

plt.title("Carbon Emissions vs Total Energy Consumption")
plt.show()

# Carbon Emissions vs Time
plt.figure(figsize=(10,5))

sns.scatterplot(
    x='Date',
    y='Carbon_Emission_tCO2e_TARGET',
    data=df
)

plt.title("Carbon Emissions vs Time")
plt.show()
# ==========================================
# Section 4: Bivariate & Multivariate Analysis
# ==========================================

# Compare Energy Sources

plt.figure(figsize=(8,5))

sns.scatterplot(
    x='Renewable_Energy_Consumption_kWh',
    y='NonRenewable_Energy_Consumption_kWh',
    data=df
)

plt.title("Renewable vs Non-Renewable Energy Consumption")
plt.show()

# Correlation Heatmap

plt.figure(figsize=(10,8))

corr = df.corr(numeric_only=True)

sns.heatmap(
    corr,
    annot=True,
    cmap='coolwarm'
)

plt.title("Correlation Heatmap")
plt.show()

# Industry Sector Boxplot

plt.figure(figsize=(12,6))

sns.boxplot(
    x='Industry_Sectors',
    y='Carbon_Emission_tCO2e_TARGET',
    data=df
)

plt.title("Carbon Emissions by Industry Sector")
plt.xticks(rotation=45)
plt.show()

# Pairplot

features = [
    'Carbon_Emission_tCO2e_TARGET',
    'Total_Energy_Consumption_kWh',
    'Production_Output_Units',
    'Supply_Chain_Transport_km'
]

sns.pairplot(df[features])
plt.show()

# Group Analysis by Industry Sector

plt.figure(figsize=(10,5))

df.groupby(
    'Industry_Sectors'
)['Carbon_Emission_tCO2e_TARGET'].mean().plot(
    kind='bar'
)

plt.title("Average Carbon Emissions by Industry Sector")
plt.ylabel("Average Emissions")
plt.show()
# ==========================================
# Section 5: Time Series Exploration
# ==========================================

import pandas as pd
import numpy as np
import matplotlib.pyplot as plt
import seaborn as sns
from statsmodels.tsa.seasonal import seasonal_decompose

# Convert Date column to datetime
df['Date'] = pd.to_datetime(df['Date'])

# Sort data by date and use Date as index
df2 = df.sort_values('Date').set_index('Date')

# ------------------------------------------
# Carbon Emissions Over Time
# ------------------------------------------

plt.figure(figsize=(15, 3))
plt.plot(df2.index,
         df2['Carbon_Emission_tCO2e_TARGET'],
         color='red')

plt.title("Carbon Emissions Over Time")
plt.xlabel("Date")
plt.ylabel("Carbon Emission (tCO2e)")
plt.show()

# ------------------------------------------
# Rolling Statistics
# Moving Average & Rolling Variance
# ------------------------------------------

window_size = 60

moving_average = (
    df2['Carbon_Emission_tCO2e_TARGET']
    .rolling(window_size)
    .mean()
)

rolling_variance = (
    df2['Carbon_Emission_tCO2e_TARGET']
    .rolling(window_size)
    .var()
)

plt.figure(figsize=(12,5))

plt.plot(
    df2['Carbon_Emission_tCO2e_TARGET'],
    alpha=0.4,
    color='gray',
    label='Original Data'
)

plt.plot(
    moving_average,
    color='blue',
    label='Moving Average'
)

plt.plot(
    rolling_variance,
    color='green',
    label='Rolling Variance'
)

plt.title("Rolling Statistics (60 Days)")
plt.legend()
plt.show()

# ------------------------------------------
# Monthly Resampling
# ------------------------------------------

monthly_data = (
    df2['Carbon_Emission_tCO2e_TARGET']
    .resample('M')
    .mean()
    .ffill()
)

# ------------------------------------------
# Time Series Decomposition
# Trend / Seasonality / Residuals
# ------------------------------------------

decomposition = seasonal_decompose(
    monthly_data,
    model='additive',
    period=12
)

fig, (ax1, ax2, ax3, ax4) = plt.subplots(
    4,
    1,
    figsize=(12,8),
    sharex=True
)

decomposition.observed.plot(
    ax=ax1,
    color='black'
)
ax1.set_ylabel('Observed')

decomposition.trend.plot(
    ax=ax2,
    color='blue'
)
ax2.set_ylabel('Trend')

decomposition.seasonal.plot(
    ax=ax3,
    color='green'
)
ax3.set_ylabel('Seasonal')

decomposition.resid.plot(
    ax=ax4,
    color='red',
    style='.'
)
ax4.set_ylabel('Residuals')

plt.tight_layout()
plt.show()
